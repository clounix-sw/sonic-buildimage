From 325ce4c329a8dedcdd2446424f95b601e6921c69 Mon Sep 17 00:00:00 2001
From: Long Wu <wulong@clounix.com>
Date: Thu, 15 Jan 2026 16:02:13 +0800
Subject: [PATCH] support sonic-restapi build

---
 Dockerfile.build | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/Dockerfile.build b/Dockerfile.build
index cf68589..ffefd1d 100644
--- a/Dockerfile.build
+++ b/Dockerfile.build
@@ -43,7 +43,7 @@ RUN rm -fr /debs
 
 RUN export VERSION=1.15 \
  && cd /tmp \
- && wget https://storage.googleapis.com/golang/go$VERSION.linux-amd64.tar.gz \
+ && wget https://dl.google.com/go/go$VERSION.linux-amd64.tar.gz \
  && tar -C /usr/local -xzf go$VERSION.linux-amd64.tar.gz \
  && rm -fr /go \
  && mkdir -m 0666 /go
